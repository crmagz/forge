{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Repository governance profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "profiles"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "uniqueItems": true
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule",
          "reason",
          "owner",
          "expires"
        ],
        "properties": {
          "rule": {
            "type": "string"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "expires": {
            "type": "string",
            "format": "date"
          }
        }
      }
    }
  }
}
